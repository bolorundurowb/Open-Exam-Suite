<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <OutputType>WinExe</OutputType>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationIcon>Creator Alt.fw.ico</ApplicationIcon>
    <NoWarn>$(NoWarn);WFO1000</NoWarn>
    <AssemblyName>OpenExamSuite.Creator</AssemblyName>
    <RootNamespace>OpenExamSuite.Creator</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Libraries\Logging\Logging.csproj" />
    <ProjectReference Include="..\..\Libraries\Shared\Shared.csproj" />
    <ProjectReference Include="..\..\Libraries\Storage\Storage.csproj" />
  </ItemGroup>
</Project>